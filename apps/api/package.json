{
  "name": "@seed/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@seed/kit": "workspace:*",
    "@seed/db": "workspace:*",
    "@seed/services": "workspace:*",
    "@seed/types": "workspace:*",
    "@neondatabase/serverless": "catalog:default",
    "better-auth": "catalog:default",
    "hono": "catalog:default",
    "hono-rate-limiter": "catalog:default",
    "zod": "catalog:default"
  },
  "devDependencies": {
    "@seed/tsconfig": "workspace:*",
    "@types/bun": "catalog:default",
    "drizzle-kit": "catalog:default",
    "dotenv": "catalog:default",
    "vitest": "3.2.4",
    "wrangler": "^4.18.0"
  }
}

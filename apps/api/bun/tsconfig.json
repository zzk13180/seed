{
  "extends": "@seed/tsconfig/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "types": ["bun", "@seed/types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "*.ts"]
}

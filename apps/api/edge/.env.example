# Server
PORT=3003
NODE_ENV=development

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/seed?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=dev-secret-key-not-for-production
BETTER_AUTH_URL=http://localhost:3003

# Redis (optional - leave empty to use in-memory cache)
REDIS_URL=

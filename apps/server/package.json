{
  "name": "@seed/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "docker:db": "./scripts/deploy.sh db -d",
    "docker:up": "./scripts/deploy.sh up -d",
    "docker:down": "./scripts/deploy.sh down",
    "docker:build": "./scripts/deploy.sh build",
    "docker:logs": "./scripts/deploy.sh logs",
    "docker:ps": "./scripts/deploy.sh ps"
  },
  "dependencies": {
    "@seed/kit": "workspace:*",
    "@seed/db": "workspace:*",
    "@seed/services": "workspace:*",
    "@seed/types": "workspace:*",
    "better-auth": "catalog:default",
    "drizzle-orm": "catalog:default",
    "hono": "catalog:default",
    "hono-rate-limiter": "catalog:default",
    "pg": "catalog:default",
    "zod": "catalog:default"
  },
  "devDependencies": {
    "@seed/tsconfig": "workspace:*",
    "@types/bun": "catalog:default",
    "@types/pg": "catalog:default",
    "dotenv": "catalog:default",
    "drizzle-kit": "catalog:default",
    "vitest": "3.2.4"
  }
}

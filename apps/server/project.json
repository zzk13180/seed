{
  "name": "@seed/server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/server/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "bun build src/main.ts --outdir dist --target bun",
        "cwd": "apps/server"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run --hot src/main.ts",
        "cwd": "apps/server"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "bun run src/main.ts",
        "cwd": "apps/server"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/server"
      },
      "outputs": ["{projectRoot}/coverage"]
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/server"
      }
    },
    "db:seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run src/seed.ts",
        "cwd": "apps/server"
      }
    }
  },
  "tags": ["type:app", "platform:bun", "framework:hono"]
}

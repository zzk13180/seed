# ========================================
# Hono + Bun Server 环境变量模板
# ========================================
# 复制为 .env.development 或 .env.production 并修改

# 应用配置
NODE_ENV=development
PORT=3003

# Better Auth 配置 (生产环境必须修改)
BETTER_AUTH_SECRET=your-super-secret-key-change-in-production-min-256-bits
BETTER_AUTH_URL=http://localhost:3003

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-password
DB_DATABASE=seed

# Redis 配置 (可选)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Tauri Updater (可选)
TAURI_UPDATER_DATA_DIR=./data/tauri-updater

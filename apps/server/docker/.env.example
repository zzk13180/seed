# ========================================
# Server API Docker Compose 环境变量
# ========================================
# 复制此文件为 .env 并修改配置值
# cp .env.example .env

# Better Auth 配置 (生产环境必须修改)
BETTER_AUTH_SECRET=your-super-secret-key-change-in-production-min-256-bits
BETTER_AUTH_URL=http://localhost:3003

# 数据库配置
DB_PASSWORD=your-db-password

# Redis 配置
REDIS_PASSWORD=your-redis-password

# 镜像标签 (生产环境使用)
IMAGE_TAG=latest

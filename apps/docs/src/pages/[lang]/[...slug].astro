---
/**
 * 文档动态路由页面
 * 
 * 使用 Astro 5.x Content Collections API
 * - 自动生成所有文档页面的静态路径
 * - 类型安全的 frontmatter 访问
 * - 自动处理 MDX 渲染
 */
import { getCollection, render } from 'astro:content'
import MainLayout from '../../../layouts/MainLayout.astro'
import { LANGUAGES, type LanguageCode } from '../../../config'

// 生成静态路径
export async function getStaticPaths() {
  const docs = await getCollection('docs')
  
  return docs.map((doc) => {
    // 从 id 解析语言和 slug
    // 例如: "zh-cn/introduction" -> lang: "zh-cn", slug: "introduction"
    const [lang, ...slugParts] = doc.id.split('/')
    const slug = slugParts.join('/')
    
    return {
      params: { lang, slug },
      props: { doc },
    }
  })
}

// 页面类型定义
type Props = {
  doc: Awaited<ReturnType<typeof getCollection<'docs'>>>[number]
}

const { doc } = Astro.props
const { lang, slug } = Astro.params as { lang: LanguageCode; slug: string }

// 渲染 MDX 内容
const { Content, headings } = await render(doc)

// 获取语言配置
const langConfig = LANGUAGES[lang] || LANGUAGES['zh-cn']
---

<MainLayout 
  title={doc.data.title}
  description={doc.data.description}
  headings={headings}
  lang={langConfig.lang}
>
  <Content />
</MainLayout>

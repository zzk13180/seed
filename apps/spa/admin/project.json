{
  "name": "@seed/spa-admin",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/spa/admin/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite serve --mode development",
        "cwd": "apps/spa/admin"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "vite build --mode production",
        "cwd": "apps/spa/admin"
      },
      "outputs": ["{projectRoot}/dist"],
      "configurations": {
        "development": {
          "command": "vite build --mode development"
        },
        "production": {
          "command": "vite build --mode production"
        }
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "vite preview",
        "cwd": "apps/spa/admin"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vue-tsc --noEmit --skipLibCheck",
        "cwd": "apps/spa/admin"
      }
    }
  },
  "tags": ["type:app", "platform:web", "framework:vue"]
}

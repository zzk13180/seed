{
  "name": "@seed/desktop",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "tauri": "tauri",
    "dev": "cd ./crates/seed && cargo tauri dev",
    "build": "cd ./crates/seed && cargo tauri build",
    "build:debug": "cd ./crates/seed && cargo tauri build --debug",
    "build:macos-universal": "cd ./crates/seed && cargo tauri build --target universal-apple-darwin",
    "build:macos-aarch64": "cd ./crates/seed && cargo tauri build --target aarch64-apple-darwin",
    "build:macos-x64": "cd ./crates/seed && cargo tauri build --target x86_64-apple-darwin",
    "build:win-x64": "cd ./crates/seed && cargo tauri build --target x86_64-pc-windows-msvc",
    "build:win-arm64": "cd ./crates/seed && cargo tauri build --target aarch64-pc-windows-msvc",
    "build:linux-x64": "cd ./crates/seed && cargo tauri build --target x86_64-unknown-linux-gnu",
    "build:linux-arm64": "cd ./crates/seed && cargo tauri build --target aarch64-unknown-linux-gnu"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.3.1",
    "@tauri-apps/plugin-log": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.5.0",
    "@tauri-apps/plugin-os": "^2.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.6.0"
  }
}
